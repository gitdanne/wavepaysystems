{
  "name": "WaveCoin-server",
  "version": "1.0.0",
  "description": "WaveCoin Banking App — Full-stack with Express + MongoDB",
  "type": "module",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "build:client": "cd client && npm install && npm run build",
    "seed": "node server/seed.js",
    "postinstall": "npm run build:client"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.0",
    "socket.io": "^4.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
